generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PMC {
  id        String  @id @default(uuid()) @db.Uuid
  name      String  @unique
  hasTracks Boolean @default(false)
  params    Param[]
  layers    Layer[]
}

model Param {
  id    String    @id @default(uuid()) @db.Uuid
  name  String
  title String    @default("")
  value String
  type  ParamType
  pmcId String    @db.Uuid
  pmc   PMC       @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

model Layer {
  id   String   @id @default(uuid()) @db.Uuid
  name String
  date DateTime @default(now())

  marker Marker[]

  pmcId String @db.Uuid
  pmc   PMC    @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

model Marker {
  id   String     @id @default(uuid()) @db.Uuid
  name String
  type MarkerType

  polygons Json @default("{}")

  layerId String @db.Uuid
  layer   Layer  @relation(fields: [layerId], references: [id], onDelete: Cascade)
}

enum ParamType {
  coords
  number
  date
  string
}

enum MarkerType {
  poly
  point
}
