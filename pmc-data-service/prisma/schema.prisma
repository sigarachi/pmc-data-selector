generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PMC {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  hasTracks Boolean  @default(false)
  dateTime  DateTime @default(now())
  markers   Marker[]
  params    Param[]
  files     File[]
}

model Param {
  id    String    @id @default(uuid()) @db.Uuid
  name  String
  value String
  type  ParamType
  pmcId String    @db.Uuid
  title String    @default("")
  pmc   PMC       @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

model Marker {
  id       String     @id @default(uuid()) @db.Uuid
  name     String
  type     MarkerType
  dateTime DateTime   @default(now())
  pmcId    String     @db.Uuid
  polygons Json       @default("{}")
  pmc      PMC        @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

model File {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @default("")
  generationDate DateTime      @default(now())
  status         FileStatus    @default(accepted)
  type           FileType      @default(single)
  path           String        @default("")
  extension      FileExtension @default(csv)
  pmcId          String?       @db.Uuid
  pmc            PMC?          @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

enum ParamType {
  coords
  number
  date
  string
}

enum MarkerType {
  poly
  point
}

enum FileStatus {
  accepted
  running
  done
  error
}

enum FileType {
  mass
  single
}

enum FileExtension {
  csv
  xlsx
}
