generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PMC {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  hasTracks Boolean  @default(false)
  dateTime  DateTime @default(now())
  layers    Layer[]
  params    Param[]
}

model Param {
  id    String    @id @default(uuid()) @db.Uuid
  name  String
  value String
  type  ParamType
  pmcId String    @db.Uuid
  title String    @default("")
  pmc   PMC       @relation(fields: [pmcId], references: [id], onDelete: Cascade)
}

model Layer {
  id     String   @id @default(uuid()) @db.Uuid
  name   String
  pmcId  String   @db.Uuid
  date   DateTime @default(now())
  pmc    PMC      @relation(fields: [pmcId], references: [id], onDelete: Cascade)
  marker Marker[]
}

model Marker {
  id       String     @id @default(uuid()) @db.Uuid
  name     String
  type     MarkerType
  layerId  String     @db.Uuid
  polygons Json       @default("{}")
  layer    Layer      @relation(fields: [layerId], references: [id], onDelete: Cascade)
}

model File {
  id             String     @id @default(uuid()) @db.Uuid
  name           String     @default("")
  generationDate DateTime   @default(now())
  status         FileStatus @default(accepted)
  path           String     @default("")
}

enum ParamType {
  coords
  number
  date
  string
}

enum MarkerType {
  poly
  point
}

enum FileStatus {
  accepted
  running
  done
  error
}
